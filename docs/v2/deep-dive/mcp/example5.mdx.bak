  rr: { title: "17. ResponseResolutionStep", stage: "RESOLVE_RESPONSE", summary: "ce_response + ce_prompt_template render transport response.", session: ["response payload"], tables: ["ce_response (R)", "ce_prompt_template (R)"] },
